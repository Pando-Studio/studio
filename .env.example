# ===========================================
# Application
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ===========================================
# BetterAuth
# ===========================================
BETTER_AUTH_SECRET=your-secret-key-here-change-in-production
BETTER_AUTH_URL=http://localhost:3001

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# Database (Studio - port 5433)
# ===========================================
DATABASE_URL=postgresql://qiplim:qiplim@localhost:5433/qiplim_studio

# ===========================================
# Redis (BullMQ)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# AI Providers (default keys - users can override with BYOK)
# ===========================================
MISTRAL_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# TTS Providers
ELEVENLABS_API_KEY=

# BYOK Encryption
BYOK_ENCRYPTION_KEY=your-encryption-key-here-change-in-production

# ===========================================
# Document Parsing
# ===========================================
# Docling (self-hosted, preferred) — set URL to enable
DOCLING_URL=http://localhost:8000
# Unstructured.io (SaaS fallback) — used when Docling is not available
UNSTRUCTURED_API_KEY=

# ===========================================
# Storage (Cellar S3 - Clever Cloud)
# ===========================================
CELLAR_ADDON_HOST=cellar-c2.services.clever-cloud.com
CELLAR_ADDON_KEY_ID=
CELLAR_ADDON_KEY_SECRET=
S3_BUCKET=studio-library
S3_REGION=eu-west-1

# ===========================================
# Cinematic Video Providers (optional)
# ===========================================
# Kling (https://klingai.com/global/dev/) — Access Key + Secret Key
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
# Runway (https://dev.runwayml.com)
RUNWAY_API_KEY=

# ===========================================
# Engage Integration
# ===========================================
NEXT_PUBLIC_ENGAGE_URL=http://localhost:3000
ENGAGE_API_SECRET=shared-secret-studio-engage-change-in-production
