generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ===========================================
// Authentication Models (BetterAuth)
// ===========================================

model user {
  id              String               @id
  email           String               @unique
  emailVerified   Boolean              @default(false)
  name            String?
  image           String?
  role            String               @default("user")
  status          String               @default("active")
  banned          Boolean              @default(false)
  banReason       String?
  banExpires      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  accounts        account[]
  sessions        session[]
  studios         Studio[]
  favorites       UserFavorite[]
  providerConfigs UserProviderConfig[]
  documentFolders DocumentFolder[]
  documentTags    DocumentTag[]
  playResults     WidgetPlayResult[]
  studioShares    StudioShare[]
  memories        UserMemory[]
  apiKeys         ApiKey[]
}

model session {
  id             String   @id
  userId         String
  expiresAt      DateTime
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  user           user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ===========================================
// Studio Models
// ===========================================

model StudioAnonymousSession {
  id        String   @id @default(cuid())
  code      String   @unique @db.VarChar(6)
  createdAt DateTime @default(now())
  expiresAt DateTime
  metadata  Json?
  studios   Studio[]

  @@index([code])
  @@map("studio_anonymous_sessions")
}

model Studio {
  id                 String                  @id @default(cuid())
  title              String
  description        String?
  userId             String?
  anonymousSessionId String?
  isAnonymous        Boolean                 @default(false)
  settings           Json                    @default("{}")
  preferredProvider  String?
  preferredModel     String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  conversations      Conversation[]
  coursePlans        CoursePlan[]
  generationRuns     GenerationRun[]
  presentations      Presentation[]
  providerConfigs    ProviderConfig[]
  sources            StudioSource[]
  anonymousSession   StudioAnonymousSession? @relation(fields: [anonymousSessionId], references: [id])
  user               user?                   @relation(fields: [userId], references: [id])
  widgets            Widget[]
  shares             StudioShare[]
  playResults        WidgetPlayResult[]
  connectors         StudioConnector[]
  deepResearchRuns   DeepResearchRun[]
  isPublic           Boolean                 @default(false)
  publicSlug         String?                 @unique

  @@index([userId])
  @@index([anonymousSessionId])
  @@map("studios")
}

model StudioConnector {
  id            String    @id @default(cuid())
  studioId      String
  connectorType String // 'google_drive', 'notion', etc.
  name          String
  config        Json // encrypted tokens, folder filters, etc.
  isActive      Boolean   @default(true)
  lastSyncAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  studio        Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@map("studio_connectors")
}

model StudioSource {
  id                 String              @id @default(cuid())
  studioId           String
  type               StudioSourceType
  title              String
  url                String?
  s3Key              String?
  mimeType           String?
  size               Int?
  status             StudioSourceStatus  @default(PENDING)
  metadata           Json?
  originWidgetId     String?
  originCoursePlanId String?
  folderId           String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  chunks             StudioSourceChunk[]
  studio             Studio              @relation(fields: [studioId], references: [id], onDelete: Cascade)
  folder             DocumentFolder?     @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags               DocumentTagSource[]

  @@index([studioId])
  @@index([status])
  @@index([folderId])
  @@map("studio_sources")
}

model StudioSourceChunk {
  id             String                   @id @default(cuid())
  sourceId       String
  content        String
  embedding      Unsupported("vector")?
  embeddingModel String?
  tsv            Unsupported("tsvector")?
  language       String?
  metadata       Json?
  pageNumber     Int?
  chunkIndex     Int                      @default(0)
  createdAt      DateTime                 @default(now())
  source         StudioSource             @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@map("studio_source_chunks")
}

model Widget {
  id            String             @id @default(cuid())
  studioId      String
  type          WidgetType
  title         String
  description   String?
  data          Json
  status        WidgetStatus       @default(DRAFT)
  order         Int                @default(0)
  runId         String?
  sourceIds     String[]           @default([])
  templateId    String?
  kind          WidgetKind         @default(LEAF)
  parentId      String?
  slotId        String?
  composition   Json?
  orchestration Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  slideWidgets  SlideWidget[]
  favorites     UserFavorite[]
  playResults   WidgetPlayResult[]
  parent        Widget?            @relation("WidgetHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children      Widget[]           @relation("WidgetHierarchy")
  studio        Studio             @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([type])
  @@index([parentId])
  @@map("widgets")
}

model Conversation {
  id                  String                @id @default(cuid())
  studioId            String
  title               String?
  summary             String?
  summaryMessageCount Int?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  messages            ConversationMessage[]
  studio              Studio                @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@map("conversations")
}

model ConversationMessage {
  id             String            @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  mode           ConversationMode?
  focusSourceId  String?
  citations      Json?
  metadata       Json?
  createdAt      DateTime          @default(now())
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("conversation_messages")
}

model Presentation {
  id        String                @id @default(cuid())
  studioId  String
  title     String
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  versions  PresentationVersion[]
  studio    Studio                @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@map("presentations")
}

model CoursePlan {
  id          String           @id @default(cuid())
  studioId    String
  title       String
  description String?
  content     Json
  metadata    Json
  status      CoursePlanStatus @default(DRAFT)
  runId       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  favorites   UserFavorite[]
  studio      Studio           @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@map("course_plans")
}

model PresentationVersion {
  id             String                    @id @default(cuid())
  presentationId String
  version        Int                       @default(1)
  status         PresentationVersionStatus @default(DRAFT)
  createdAt      DateTime                  @default(now())
  presentation   Presentation              @relation(fields: [presentationId], references: [id], onDelete: Cascade)
  slides         Slide[]

  @@unique([presentationId, version])
  @@index([presentationId])
  @@map("presentation_versions")
}

model Slide {
  id                    String              @id @default(cuid())
  presentationVersionId String
  order                 Int                 @default(0)
  content               Json
  notes                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  slideWidgets          SlideWidget[]
  presentationVersion   PresentationVersion @relation(fields: [presentationVersionId], references: [id], onDelete: Cascade)

  @@index([presentationVersionId])
  @@map("slides")
}

model SlideWidget {
  id       String @id @default(cuid())
  slideId  String
  widgetId String
  position Json?
  slide    Slide  @relation(fields: [slideId], references: [id], onDelete: Cascade)
  widget   Widget @relation(fields: [widgetId], references: [id], onDelete: Cascade)

  @@unique([slideId, widgetId])
  @@map("slide_widgets")
}

model ProviderConfig {
  id        String     @id @default(cuid())
  studioId  String
  provider  AIProvider
  apiKey    String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  studio    Studio     @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@unique([studioId, provider])
  @@map("provider_configs")
}

model GenerationRun {
  id              String              @id @default(cuid())
  studioId        String
  type            GenerationRunType
  status          GenerationRunStatus @default(PENDING)
  widgetId        String?
  presentationId  String?
  slideId         String?
  estimatedTokens Int?
  actualTokens    Int?
  errorLog        String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  completedAt     DateTime?
  studio          Studio              @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@index([status])
  @@map("generation_runs")
}

model UserFavorite {
  id           String      @id @default(cuid())
  userId       String
  widgetId     String?
  coursePlanId String?
  createdAt    DateTime    @default(now())
  user         user        @relation(fields: [userId], references: [id], onDelete: Cascade)
  widget       Widget?     @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  coursePlan   CoursePlan? @relation(fields: [coursePlanId], references: [id], onDelete: Cascade)

  @@unique([userId, widgetId])
  @@unique([userId, coursePlanId])
  @@index([userId])
  @@map("user_favorites")
}

model UserProviderConfig {
  id        String     @id @default(cuid())
  userId    String
  provider  AIProvider
  apiKey    String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      user       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("user_provider_configs")
}

model DocumentFolder {
  id        String           @id @default(cuid())
  userId    String
  name      String
  parentId  String?
  color     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      user             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    DocumentFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  DocumentFolder[] @relation("FolderTree")
  sources   StudioSource[]

  @@index([userId])
  @@map("document_folders")
}

model DocumentTag {
  id        String              @id @default(cuid())
  userId    String
  name      String
  color     String              @default("#6B7280")
  createdAt DateTime            @default(now())
  user      user                @relation(fields: [userId], references: [id], onDelete: Cascade)
  sources   DocumentTagSource[]

  @@unique([userId, name])
  @@index([userId])
  @@map("document_tags")
}

model DocumentTagSource {
  id       String       @id @default(cuid())
  tagId    String
  sourceId String
  tag      DocumentTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  source   StudioSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([tagId, sourceId])
  @@map("document_tag_sources")
}

// ===========================================
// User Memory
// ===========================================

model UserMemory {
  id        String   @id @default(cuid())
  userId    String
  category  String // 'preference', 'context', 'pedagogical', 'directive'
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_memories")
}

// ===========================================
// Deep Research
// ===========================================

model DeepResearchRun {
  id            String    @id @default(cuid())
  studioId      String
  query         String
  status        String    @default("pending") // pending, searching, scraping, indexing, completed, failed
  pagesFound    Int?
  pagesRetained Int?
  summary       String?
  metadata      Json?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?
  studio        Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@index([studioId])
  @@map("deep_research_runs")
}

// ===========================================
// API Keys
// ===========================================

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  user       user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

// ===========================================
// Enums
// ===========================================

enum StudioSourceType {
  DOCUMENT
  WEB
  YOUTUBE
  WIDGET
  AUDIO
  VIDEO
}

enum StudioSourceStatus {
  PENDING
  INDEXING
  INDEXED
  ERROR
}

enum WidgetType {
  QUIZ
  WORDCLOUD
  ROLEPLAY
  PRESENTATION
  SLIDE
  MULTIPLE_CHOICE
  POSTIT
  RANKING
  OPENTEXT
  SEQUENCE
  COURSE_MODULE
  IMAGE
  FAQ
  GLOSSARY
  SUMMARY
  FLASHCARD
  TIMELINE
  REPORT
  DATA_TABLE
  AUDIO
  VIDEO
  MINDMAP
  INFOGRAPHIC
  SYLLABUS
  SESSION_PLAN
  PROGRAM_OVERVIEW
  CLASS_OVERVIEW
  QCM
}

enum WidgetKind {
  LEAF
  COMPOSED
}

enum UserRole {
  ADMIN
  CREATOR
  VIEWER
}

enum ShareRole {
  EDITOR
  VIEWER
}

// ===========================================
// Self-paced play results
// ===========================================

model WidgetPlayResult {
  id          String    @id @default(cuid())
  widgetId    String
  userId      String
  studioId    String
  status      String    @default("started") // started | completed
  score       Float? // 0-100 percentage
  maxScore    Float?
  duration    Int? // seconds
  attempts    Int       @default(1)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  widget      Widget    @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  user        user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  studio      Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@unique([widgetId, userId])
  @@index([studioId])
  @@index([userId])
  @@map("widget_play_results")
}

// ===========================================
// Studio sharing
// ===========================================

model StudioShare {
  id        String    @id @default(cuid())
  studioId  String
  userId    String?
  email     String?
  role      ShareRole @default(VIEWER)
  createdAt DateTime  @default(now())
  studio    Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)
  user      user?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([studioId, userId])
  @@index([studioId])
  @@index([userId])
  @@map("studio_shares")
}

// ===========================================
// Instance configuration (singleton)
// ===========================================

model InstanceConfig {
  id             String   @id @default("singleton")
  name           String   @default("Qiplim Studio")
  logo           String?
  locale         String   @default("generic")
  enabledWidgets String[] @default([])
  settings       Json     @default("{}")
  updatedAt      DateTime @updatedAt

  @@map("instance_config")
}

enum WidgetStatus {
  DRAFT
  GENERATING
  READY
  ERROR
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ConversationMode {
  ASK
  PLAN
  AGENT
}

enum CoursePlanStatus {
  DRAFT
  GENERATING
  READY
  ERROR
  PUBLISHED
}

enum PresentationVersionStatus {
  DRAFT
  GENERATING
  READY
  PUBLISHED
}

enum AIProvider {
  MISTRAL
  OPENAI
  ANTHROPIC
  GOOGLE
}

enum GenerationRunType {
  QUIZ
  WORDCLOUD
  ROLEPLAY
  PRESENTATION
  COURSE_PLAN
  SLIDES
  SLIDE
  DECK_PLAN
  CHAT
  MULTIPLE_CHOICE
  POSTIT
  RANKING
  OPENTEXT
  SEQUENCE
  COURSE_MODULE
  IMAGE
  FAQ
  GLOSSARY
  SUMMARY
  FLASHCARD
  TIMELINE
  REPORT
  DATA_TABLE
  AUDIO
  VIDEO
  MINDMAP
  INFOGRAPHIC
  SYLLABUS
  SESSION_PLAN
  PROGRAM_OVERVIEW
  CLASS_OVERVIEW
  QCM
}

enum GenerationRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
